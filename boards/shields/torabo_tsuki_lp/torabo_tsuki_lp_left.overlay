#include "torabo_tsuki_lp.dtsi"
#include <input/processors.dtsi>
#include <dt-bindings/zmk/input_transform.h>
#include <scroll-snap.dtsi>

/* =============================================
 * 左手トラックパッド（IQS7211E）の入力設定
 * ============================================= */

&pointing_listener {
    /* 
     * 現在：左→上、下→右 ということは時計回り90度ずれている
     * → 反時計回り90度に修正 
     */
    input-processors = <&zip_xy_transform (INPUT_TRANSFORM_XY_SWAP | INPUT_TRANSFORM_Y_INVERT)>;
};

/* 必要に応じてスクロールスナップも左手で有効化 */
&pointing_listener {
    scroller {
        layers = <2 5>;
        input-processors = <
            &zip_xy_to_scroll_mapper
            &zip_scroll_snap
        >;
    };
};
